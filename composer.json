{
    "name": "veoksha/pdfit",
    "version": "1.0.3",
    "description": "Convert DOCX Excel PowerPoint images HTML Markdown to PDF in Laravel. No API, no microservice. Works with Azure Cloud Run Docker.",
    "keywords": [
        "laravel",
        "pdf",
        "converter",
        "docx",
        "document",
        "images",
        "weasyprint",
        "libreoffice",
        "office",
        "word",
        "excel",
        "powerpoint",
        "xlsx",
        "pptx",
        "markdown",
        "html-to-pdf",
        "document-conversion"
    ],
    "homepage": "https://github.com/spiderdev27/pdfit",
    "support": {
        "issues": "https://github.com/spiderdev27/pdfit/issues",
        "source": "https://github.com/spiderdev27/pdfit"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Mohit Anand",
            "email": "admin@veoksha.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "symfony/process": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Veoksha\\LaravelUniversalConverter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Veoksha\\LaravelUniversalConverter\\ConverterServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-install-cmd": [
            "Veoksha\\LaravelUniversalConverter\\Scripts::installUv"
        ],
        "post-update-cmd": [
            "Veoksha\\LaravelUniversalConverter\\Scripts::installUv"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
